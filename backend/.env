# ==================== SERVER CONFIGURATION ====================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ==================== JWT CONFIGURATION ====================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-2024
JWT_ACCESS_SECRET=your-access-token-secret-different-from-refresh-2024
JWT_REFRESH_SECRET=your-refresh-token-secret-different-from-access-2024

# Token Expiry Times
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ==================== DATABASE CONFIGURATION (FIXED) ====================
# MongoDB Atlas Connection String - CORRECTED
# MONGODB_URI=mongodb+srv://mongodb734_db_user:Tender_db@cluster0.l3efxck.mongodb.net/smart_tender_db?retryWrites=true&w=majority&appName=Cluster0
# MONGODB_URI=mongodb+srv://mongodb734_db_user:Tender_db@cluster0.xxxxx.mongodb.net/smart_tender_db
# Local MongoDB (Alternative)
MONGODB_URI=mongodb://localhost:27017/smart_tender_db

# ==================== REDIS CONFIGURATION ====================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TTL=3600

# ==================== EMAIL CONFIGURATION ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@smarttender.com

# ==================== SECURITY SETTINGS ====================
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_TIME=30
SESSION_TIMEOUT_DAYS=7
PASSWORD_HISTORY_COUNT=5

# ==================== API RATE LIMITING ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== INGESTION SETTINGS ====================
INGESTION_INTERVAL_MINUTES=60
INGESTION_SOURCES=gem,eproc

# ==================== LOGGING ====================
LOG_LEVEL=info
LOG_DIR=logs